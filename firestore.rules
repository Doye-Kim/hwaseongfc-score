rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // games - 누구나 읽기 가능, 쓰기는 관리자만
    match /games/{gameId} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // predictions - 단건 조회는 누구나 가능, 리스트 조회/수정/삭제는 관리자만
		match /predictions/{predictionId} {
  		allow create: if exists(/databases/$(database)/documents/games/$(request.resource.data.gameId));
  		allow get: if true;
  		allow list, update, delete: if request.auth != null && 
    		get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
		}
    // quizzes - 누구나 읽기 가능, 쓰기는 관리자만                            
    match /quizzes/{quizId} {                                                 
      allow read: if true;                                                    
      allow write: if request.auth != null &&                                                                          
  			get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;  
    }
                                                                                
    // participants - 단건 조회/쓰기(퀴즈가 active일 때만)는 누구나 가능, 리스트 조회/수정/삭제는 관리자만
		match /participants/{participantId} {
    	allow get: if true;
      allow list: if request.auth != null && 
      	get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    	allow create: if exists(/databases/$(database)/documents/quizzes/$(request.resource.data.quizId)) &&
      		request.time >= get(/databases/$(database)/documents/quizzes/$(request.resource.data.quizId)).data.openTime &&
      		request.time <= get(/databases/$(database)/documents/quizzes/$(request.resource.data.quizId)).data.closeTime;
    	allow update, delete: if request.auth != null &&
      	get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
  	}

    // users - 본인만 읽기 가능, 쓰기 불가
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // _serverTime - 누구나 읽기 가능
    match /_serverTime/{doc} {
      allow read, write: if true;
    }
  }
}